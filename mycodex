#!/usr/bin/env bash

MYCODEX_SOURCE_PATH="${BASH_SOURCE[0]}"

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  set -euo pipefail
fi

BASE_DIR="${MYCODEX_BASE_DIR:-$HOME/.mycodex/accounts}"
BIN_NAME="mycodex"
PARSED_SHELL_NAME=""
PARSED_TARGET_RC=""
SCANNED_ACCOUNTS=()
SCANNED_HIDDEN_STUB_COUNT=0

BOLD=""
DIM=""
GREEN=""
YELLOW=""
RED=""
BLUE=""
RESET=""

init_ui() {
  if [[ -t 1 ]] && command -v tput >/dev/null 2>&1 && [[ "${TERM:-}" != "dumb" ]]; then
    if [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
      BOLD="$(tput bold)"
      DIM="$(tput dim)"
      GREEN="$(tput setaf 2)"
      YELLOW="$(tput setaf 3)"
      RED="$(tput setaf 1)"
      BLUE="$(tput setaf 4)"
      RESET="$(tput sgr0)"
    fi
  fi
}

ui_section() {
  printf '%s%s%s\n' "$BOLD" "$1" "$RESET"
}

ui_kv() {
  printf '  %-12s %s\n' "$1" "$2"
}

ui_ok() {
  printf '%sok%s    %s\n' "$GREEN" "$RESET" "$1"
}

ui_warn() {
  printf '%swarn%s  %s\n' "$YELLOW" "$RESET" "$1"
}

ui_note() {
  printf '%snote%s  %s\n' "$DIM" "$RESET" "$1"
}

ui_error() {
  printf '%serror%s %s\n' "$RED" "$RESET" "$1" >&2
}

mycodex_shell_marker_value() {
  local marker="$1"
  local file="$BASE_DIR/.${marker}"

  if [[ -f "$file" ]]; then
    cat "$file"
  fi
}

mycodex_shell_selected_account() {
  local account
  account="$(mycodex_shell_marker_value current)"
  if [[ -n "$account" ]]; then
    printf '%s\n' "$account"
    return
  fi

  account="$(mycodex_shell_marker_value default)"
  if [[ -n "$account" ]]; then
    printf '%s\n' "$account"
  fi
}

mycodex_shell_selected_home() {
  local account
  account="$(mycodex_shell_selected_account)"
  if [[ -z "$account" ]]; then
    return
  fi

  printf '%s/%s\n' "$BASE_DIR" "$account"
}

mycodex_enable_shell_integration() {
  mycodex() {
    local bin="$MYCODEX_SOURCE_PATH"

    if [[ ! -x "$bin" ]]; then
      printf 'mycodex shell error: executable not found at %s\n' "$bin" >&2
      return 127
    fi

    command "$bin" "$@"
  }

  codex() {
    local selected_home

    if [[ -n "${CODEX_HOME:-}" ]]; then
      command codex "$@"
      return
    fi

    selected_home="$(mycodex_shell_selected_home)"
    if [[ -n "$selected_home" ]] && [[ -d "$selected_home" ]]; then
      CODEX_HOME="$selected_home" command codex "$@"
      return
    fi

    command codex "$@"
  }
}

usage() {
  cat <<'EOF2'
MyCodex
  Fast account switching for Codex CLI using isolated CODEX_HOME directories.

Usage:
  mycodex login <name>
  mycodex use <name>
  mycodex list
  mycodex usage [--json] [name]
  mycodex current
  mycodex default <name>
  mycodex uninstall [--shell bash|zsh] [--rc-file <path>]
  mycodex logout <name>
  mycodex forget <name>
  mycodex prune [--dry-run]
  mycodex where <name>
  mycodex help

Commands:
  login <name>       Log into an account and store auth under its own CODEX_HOME.
  use <name>         Select an account and mark it current without launching codex.
  list               Show saved accounts, email, and local paths.
  usage              Show saved accounts with email and 5h/week limits.
  current            Print the current account name.
  default <name>     Set the fallback account used when no current account is selected.
  uninstall          Remove mycodex, shell integration, and all saved local account data.
  logout <name>      Clear current/default pointer only; keep saved auth.
  forget <name>      Remove saved auth; if active, auto-switch markers first when possible.
  prune              Remove removable stub accounts with no saved auth.
  where <name>       Print the account directory path.
  help               Show this help output.

Examples:
  mycodex login <name>
  mycodex use <name>
  codex -m gpt-5.4
  mycodex default <name>
  mycodex uninstall
  mycodex usage
  mycodex usage <name> --json
  mycodex prune --dry-run
  mycodex logout <name>
  mycodex forget <name>

Notes:
  <name> is any local label you choose, for example: work, personal, or client-a.
  uninstall is destructive. It deletes saved auth and local account data under ~/.mycodex/accounts.
  logout is safe for fast account switching. It does not delete auth.json.
  forget is destructive. It deletes the saved login for that account.
  if the forgotten account is current/default, mycodex auto-switches those markers first when it can.
  use only selects the current account. Run normal `codex` after that.
  list and usage hide stub accounts without saved auth.
  usage is local-first and inferred from saved auth.json plus codex-tui.log.
EOF2
}

resolve_path() {
  local path="$1"

  if command -v readlink >/dev/null 2>&1; then
    readlink -f "$path" 2>/dev/null && return
  fi

  printf '%s\n' "$path"
}

default_shell_rc() {
  local shell_name="${1:-bash}"

  if [[ "$shell_name" == "zsh" ]]; then
    printf '%s\n' "$HOME/.zshrc"
  else
    printf '%s\n' "$HOME/.bashrc"
  fi
}

remove_shell_integration_lines() {
  local target_rc="$1"

  sed -i '\|^source ~/.mycodex/mycodex\.sh$|d' "$target_rc"
  sed -i '\|^\[ -f "\$HOME/\.local/bin/mycodex" \] && source "\$HOME/\.local/bin/mycodex"$|d' "$target_rc"
}

install_cmd_help() {
  local command_name="$1"

  cat <<EOF2
Usage:
  mycodex $command_name
  mycodex $command_name --shell bash
  mycodex $command_name --rc-file /path/to/rc

What it does:
  - symlink mycodex into ~/.local/bin
  - ensure ~/.local/bin is in PATH
  - source mycodex from the chosen shell rc file for codex account switching
EOF2
}

uninstall_cmd_help() {
  cat <<'EOF2'
Usage:
  mycodex uninstall
  mycodex uninstall --shell bash
  mycodex uninstall --rc-file /path/to/rc

What it does:
  - remove ~/.local/bin/mycodex
  - remove the mycodex shell integration line from the chosen shell rc file
  - remove ~/.mycodex/accounts and saved auth data
EOF2
}

parse_shell_rc_args() {
  local command_name="$1"
  local help_kind="$2"
  shift 2

  PARSED_SHELL_NAME="$(basename "${SHELL:-bash}")"
  PARSED_TARGET_RC=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --shell)
        if [[ $# -lt 2 ]]; then
          ui_error "missing value for --shell"
          exit 1
        fi
        PARSED_SHELL_NAME="${2:-}"
        shift
        ;;
      --rc-file)
        if [[ $# -lt 2 ]]; then
          ui_error "missing value for --rc-file"
          exit 1
        fi
        PARSED_TARGET_RC="${2:-}"
        shift
        ;;
      -h|--help)
        if [[ "$help_kind" == "install" ]]; then
          install_cmd_help "$command_name"
        else
          uninstall_cmd_help
        fi
        return 1
        ;;
      *)
        ui_error "unknown flag for $command_name: $1"
        exit 1
        ;;
    esac
    shift
  done

  if [[ -z "$PARSED_TARGET_RC" ]]; then
    PARSED_TARGET_RC="$(default_shell_rc "$PARSED_SHELL_NAME")"
  fi
}

ensure_local_bin_path_line() {
  local target_rc="$1"
  local add_path_line='export PATH="$HOME/.local/bin:$PATH"'

  touch "$target_rc"
  if ! grep -Fq "$add_path_line" "$target_rc"; then
    printf '\n%s\n' "$add_path_line" >> "$target_rc"
  fi
}

install_shell_integration_line() {
  local target_rc="$1"
  local source_line='[ -f "$HOME/.local/bin/mycodex" ] && source "$HOME/.local/bin/mycodex"'

  remove_shell_integration_lines "$target_rc"
  printf '%s\n' "$source_line" >> "$target_rc"
}

remove_shell_integration_if_present() {
  local target_rc="$1"
  local source_line='[ -f "$HOME/.local/bin/mycodex" ] && source "$HOME/.local/bin/mycodex"'

  if [[ ! -f "$target_rc" ]]; then
    ui_note "Shell rc file not found: $target_rc"
    return
  fi

  if grep -Fq "$source_line" "$target_rc" || grep -Fq 'source ~/.mycodex/mycodex.sh' "$target_rc"; then
    remove_shell_integration_lines "$target_rc"
    ui_kv "shell_rc" "$target_rc"
    ui_note "Removed mycodex shell integration from $target_rc"
  else
    ui_note "No mycodex shell integration line found in $target_rc"
  fi
}

remove_managed_source_copy() {
  local src="$1"

  if [[ "$src" == "$HOME/.local/share/mycodex/"* ]] && [[ -f "$src" ]]; then
    rm -f "$src"
    ui_kv "removed" "$src"
    rmdir "$(dirname "$src")" 2>/dev/null || true
  fi
}

remove_account_data_tree() {
  if [[ -d "$BASE_DIR" ]]; then
    rm -rf "$BASE_DIR"
    ui_kv "removed" "$BASE_DIR"
  else
    ui_note "No saved account data found under $BASE_DIR"
  fi

  if [[ "$BASE_DIR" == "$HOME/.mycodex/accounts" ]]; then
    rmdir "$HOME/.mycodex" 2>/dev/null || true
  fi
}

cmd_install_like() {
  local command_name="$1"
  shift
  local dest_dir="$HOME/.local/bin"
  local src

  if ! parse_shell_rc_args "$command_name" "install" "$@"; then
    return
  fi

  src="$(resolve_path "$MYCODEX_SOURCE_PATH")"

  mkdir -p "$dest_dir"
  chmod +x "$src"
  ln -sfn "$src" "$dest_dir/mycodex"

  ensure_local_bin_path_line "$PARSED_TARGET_RC"
  install_shell_integration_line "$PARSED_TARGET_RC"

  ui_section "Install"
  ui_kv "source" "$src"
  ui_kv "symlink" "$dest_dir/mycodex"
  ui_kv "shell_rc" "$PARSED_TARGET_RC"
  ui_note "Open a new terminal or run: source $PARSED_TARGET_RC"
  ui_note "Then use: mycodex login <name>, mycodex use <name>, then codex"
}

cmd_install() {
  cmd_install_like "install" "$@"
}

cmd_uninstall() {
  local dest="$HOME/.local/bin/mycodex"
  local src

  if ! parse_shell_rc_args "uninstall" "uninstall" "$@"; then
    return
  fi

  src="$(resolve_path "$MYCODEX_SOURCE_PATH")"

  ui_section "Uninstall"

  if [[ -e "$dest" || -L "$dest" ]]; then
    rm -f "$dest"
    ui_kv "removed" "$dest"
  else
    ui_note "No installed mycodex symlink found at $dest"
  fi

  remove_shell_integration_if_present "$PARSED_TARGET_RC"
  remove_managed_source_copy "$src"
  remove_account_data_tree

  ui_note "Saved auth and local account data were removed."
  ui_note "~/.local/bin is still left in PATH in case other tools use it."
  ui_note "Open a new terminal or run: source $PARSED_TARGET_RC"
}

usage_cmd_help() {
  cat <<'EOF2'
Usage:
  mycodex usage
  mycodex usage <name>
  mycodex usage --json [name]

Modes:
  mycodex usage            Show all accounts with plan, status, and 5h/week limits.
  mycodex usage <name>     Show one account in detail, including reset times.

What it shows:
  auth        Whether local auth.json exists for the account.
  email       Email decoded from the saved id_token when available.
  plan        Plan hint decoded from the saved id_token when available.
  status      ready, session_limited, weekly_limited, limit_seen, or logged_out.
  5h/week     Used percent plus reset time from the latest local token_count event.
  retry_at    Next retry time parsed from the latest local usage-limit log entry.

Notes:
  <name> is any local label you choose, for example: work, personal, or client-a.
  This command is local-first. It does not call a live billing or usage API.
  Text output shows times in your local time zone; `--json` keeps raw timestamps.
  Plan and status can be stale until tokens refresh or new log entries are written.
  Stub accounts without saved auth are hidden; use `mycodex prune --dry-run` to inspect them.
EOF2
}

ensure_codex() {
  if ! command -v codex >/dev/null 2>&1; then
    ui_error "'codex' command not found in PATH."
    exit 1
  fi
}

account_dir() {
  local account="$1"
  echo "$BASE_DIR/$account"
}

validate_account() {
  local account="${1:-}"
  if [[ -z "$account" ]]; then
    ui_error "missing account name."
    usage
    exit 1
  fi
  if [[ ! "$account" =~ ^[a-zA-Z0-9._-]+$ ]]; then
    ui_error "invalid account name '$account'. Use only letters, numbers, dot, underscore, hyphen."
    exit 1
  fi
}

setup_account_dir() {
  local account="$1"
  local dir
  dir="$(account_dir "$account")"
  mkdir -p "$dir"
  local config="$dir/config.toml"
  if [[ ! -f "$config" ]]; then
    cat > "$config" <<'EOF2'
cli_auth_credentials_store = "file"
EOF2
  elif ! grep -q 'cli_auth_credentials_store' "$config"; then
    printf '\ncli_auth_credentials_store = "file"\n' >> "$config"
  fi
}

set_current() {
  local account="$1"
  mkdir -p "$BASE_DIR"
  printf '%s\n' "$account" > "$BASE_DIR/.current"
}

get_current() {
  if [[ -f "$BASE_DIR/.current" ]]; then
    cat "$BASE_DIR/.current"
  fi
}

set_default() {
  local account="$1"
  mkdir -p "$BASE_DIR"
  printf '%s\n' "$account" > "$BASE_DIR/.default"
}

get_default() {
  if [[ -f "$BASE_DIR/.default" ]]; then
    cat "$BASE_DIR/.default"
  fi
}

clear_current() {
  rm -f "$BASE_DIR/.current"
}

clear_default() {
  rm -f "$BASE_DIR/.default"
}

load_marker_state() {
  MARKER_CURRENT="$(get_current || true)"
  MARKER_DEFAULT="$(get_default || true)"
}

account_has_saved_auth() {
  local account="$1"
  [[ -f "$(account_dir "$account")/auth.json" ]]
}

collect_saved_accounts() {
  local exclude_account="${1:-}"
  local dir account

  SCANNED_ACCOUNTS=()
  SCANNED_HIDDEN_STUB_COUNT=0

  shopt -s nullglob
  for dir in "$BASE_DIR"/*; do
    [[ -d "$dir" ]] || continue
    account="$(basename "$dir")"
    [[ "$account" == .* || "$account" == "$exclude_account" ]] && continue
    if account_is_stub "$account"; then
      SCANNED_HIDDEN_STUB_COUNT=$((SCANNED_HIDDEN_STUB_COUNT + 1))
      continue
    fi
    SCANNED_ACCOUNTS+=("$account")
  done
  shopt -u nullglob
}

collect_prunable_accounts() {
  local dir account

  SCANNED_ACCOUNTS=()
  shopt -s nullglob
  for dir in "$BASE_DIR"/*; do
    [[ -d "$dir" ]] || continue
    account="$(basename "$dir")"
    [[ "$account" == .* ]] && continue
    if account_is_prunable "$account"; then
      SCANNED_ACCOUNTS+=("$account")
    fi
  done
  shopt -u nullglob
}

show_hidden_stub_note() {
  local hidden_count="$1"

  if [[ "$hidden_count" -gt 0 ]]; then
    ui_note "Hidden $hidden_count stub account(s) without saved auth. Run '$BIN_NAME prune --dry-run' to inspect them."
  fi

  return 0
}

show_no_saved_accounts_message() {
  local hidden_count="$1"

  if [[ "$hidden_count" -gt 0 ]]; then
    ui_warn "No saved accounts found under $BASE_DIR."
    show_hidden_stub_note "$hidden_count"
  else
    ui_warn "No accounts found under $BASE_DIR."
  fi
}

first_saved_replacement_account() {
  local excluded_account="$1"

  collect_saved_accounts "$excluded_account"
  if [[ "${#SCANNED_ACCOUNTS[@]}" -gt 0 ]]; then
    printf '%s\n' "${SCANNED_ACCOUNTS[0]}"
  fi

  return 0
}

account_is_stub() {
  local account="$1"
  local dir
  dir="$(account_dir "$account")"

  [[ -d "$dir" ]] && ! account_has_saved_auth "$account"
}

account_is_prunable() {
  local account="$1"
  local dir
  local -a remaining=()
  local path base

  dir="$(account_dir "$account")"
  if [[ ! -d "$dir" ]] || account_has_saved_auth "$account"; then
    return 1
  fi

  while IFS= read -r path; do
    base="$(basename "$path")"
    case "$base" in
      config.toml)
        ;;
      *)
        remaining+=("$path")
        ;;
    esac
  done < <(find "$dir" -mindepth 1 -maxdepth 1)

  [[ "${#remaining[@]}" -eq 0 ]]
}

json_get() {
  local file="$1"
  local jq_filter="$2"
  local fallback_key="${3:-}"

  if command -v jq >/dev/null 2>&1; then
    jq -r "$jq_filter // empty" "$file" 2>/dev/null || true
    return
  fi

  if [[ -n "$fallback_key" ]]; then
    sed -nE "s/.*\"$fallback_key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\".*/\\1/p" "$file" | head -n 1
  fi
}

json_has_non_null() {
  local file="$1"
  local jq_filter="$2"
  local fallback_key="${3:-}"

  if command -v jq >/dev/null 2>&1; then
    jq -e "$jq_filter != null and $jq_filter != \"\"" "$file" >/dev/null 2>&1
    return
  fi

  if [[ -n "$fallback_key" ]] && grep -Eq "\"$fallback_key\"[[:space:]]*:[[:space:]]*null" "$file"; then
    return 1
  fi

  if [[ -n "$fallback_key" ]] && grep -Eq "\"$fallback_key\"[[:space:]]*:[[:space:]]*\"" "$file"; then
    return 0
  fi

  return 1
}

decode_jwt_payload() {
  local token="$1"
  local payload

  if [[ -z "$token" ]] || ! command -v base64 >/dev/null 2>&1; then
    return
  fi

  payload="${token#*.}"
  payload="${payload%%.*}"
  payload="${payload//-/+}"
  payload="${payload//_/\/}"

  case $((${#payload} % 4)) in
    2)
      payload="${payload}=="
      ;;
    3)
      payload="${payload}="
      ;;
  esac

  printf '%s' "$payload" | base64 -d 2>/dev/null || true
}

jwt_claim() {
  local token="$1"
  local jq_filter="$2"
  local payload

  payload="$(decode_jwt_payload "$token")"
  if [[ -z "$payload" ]] || ! command -v jq >/dev/null 2>&1; then
    return
  fi

  printf '%s' "$payload" | jq -r "$jq_filter // empty" 2>/dev/null || true
}

normalize_retry_time() {
  printf '%s' "$1" | sed -E 's/([0-9]{1,2})(st|nd|rd|th)/\1/g'
}

retry_is_future() {
  local retry_at="$1"
  local normalized retry_epoch now_epoch

  if [[ -z "$retry_at" ]]; then
    return 1
  fi

  normalized="$(normalize_retry_time "$retry_at")"
  retry_epoch="$(date -d "$normalized" +%s 2>/dev/null || true)"
  now_epoch="$(date +%s)"

  [[ "$retry_epoch" =~ ^[0-9]+$ ]] && (( retry_epoch > now_epoch ))
}

latest_token_count_line() {
  local dir="$1"
  local sessions_dir="$dir/sessions"
  local -a session_files=()
  local file line idx

  if [[ ! -d "$sessions_dir" ]]; then
    return
  fi

  while IFS= read -r file; do
    session_files+=("$file")
  done < <(find "$sessions_dir" -type f -name '*.jsonl' | sort)

  for ((idx=${#session_files[@]} - 1; idx >= 0; idx--)); do
    line="$(grep -F '"type":"event_msg","payload":{"type":"token_count"' "${session_files[idx]}" | tail -n 1 || true)"
    if [[ -n "$line" ]]; then
      printf '%s\n' "$line"
      return
    fi
  done
}

epoch_to_utc() {
  local epoch="$1"

  if [[ -z "$epoch" ]] || ! [[ "$epoch" =~ ^[0-9]+$ ]]; then
    return
  fi

  date -u -d "@$epoch" '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || true
}

local_time_zone_label() {
  local offset

  offset="$(date '+%:z' 2>/dev/null || true)"
  if [[ -n "$offset" ]]; then
    printf 'UTC%s' "$offset"
    return
  fi

  offset="$(date '+%z' 2>/dev/null || true)"
  if [[ -n "$offset" ]]; then
    printf 'UTC%s' "$offset"
    return
  fi

  printf '%s' "local time"
}

format_datetime_local() {
  local value="$1"
  local style="${2:-detail}"
  local fmt

  if [[ -z "$value" ]]; then
    return
  fi

  case "$style" in
    table)
      fmt='+%Y-%m-%d %H:%M'
      ;;
    *)
      fmt='+%Y-%m-%d %H:%M:%S'
      ;;
  esac

  date -d "$value" "$fmt" 2>/dev/null || printf '%s' "$value"
}

format_datetime_local_or_dash() {
  local value="$1"
  local style="${2:-detail}"

  if [[ -z "$value" ]]; then
    printf '%s' "-"
    return
  fi

  format_datetime_local "$value" "$style"
}

percent_ge_100() {
  local value="${1:-}"
  local whole

  if [[ -z "$value" ]]; then
    return 1
  fi

  whole="${value%.*}"
  [[ "$whole" =~ ^[0-9]+$ ]] && (( whole >= 100 ))
}

format_percent() {
  local value="${1:-}"
  local formatted

  if [[ -z "$value" ]]; then
    printf '%s' "-"
    return
  fi

  if [[ "$value" =~ ^[0-9]+([.][0-9]+)?$ ]]; then
    formatted="$(awk -v value="$value" 'BEGIN {
      if (value + 0 == int(value + 0)) {
        printf "%.1f", value + 0
      } else {
        printf "%.2f", value + 0
      }
    }')"
    formatted="${formatted%0}"
    if [[ "$formatted" == *"." ]]; then
      formatted="${formatted}0"
    fi
    printf '%s%%' "$formatted"
    return
  fi

  printf '%s%%' "$value"
}

usage_reset_record() {
  REC_ACCOUNT=""
  REC_PATH=""
  REC_CURRENT="no"
  REC_DEFAULT="no"
  REC_AUTH="missing"
  REC_AUTH_MODE="unknown"
  REC_EMAIL=""
  REC_PLAN="unknown"
  REC_PLAN_UNTIL=""
  REC_PLAN_CHECKED_AT=""
  REC_STATUS="logged_out"
  REC_REASON=""
  REC_RETRY_AT=""
  REC_LAST_LIMIT_AT=""
  REC_LAST_REFRESH=""
  REC_LIMITS_AT=""
  REC_PRIMARY_USED=""
  REC_PRIMARY_WINDOW_MIN=""
  REC_PRIMARY_RESET_AT=""
  REC_SECONDARY_USED=""
  REC_SECONDARY_WINDOW_MIN=""
  REC_SECONDARY_RESET_AT=""
  REC_ACCOUNT_ID=""
}

usage_record_apply_auth_file() {
  local auth_file="$1"
  local id_token

  if [[ ! -f "$auth_file" ]]; then
    return
  fi

  REC_AUTH="saved"
  REC_STATUS="ready"
  REC_AUTH_MODE="$(json_get "$auth_file" '.auth_mode' 'auth_mode')"
  REC_LAST_REFRESH="$(json_get "$auth_file" '.last_refresh' 'last_refresh')"
  REC_ACCOUNT_ID="$(json_get "$auth_file" '.tokens.account_id' 'account_id')"
  id_token="$(json_get "$auth_file" '.tokens.id_token' 'id_token')"

  if [[ -z "$id_token" ]]; then
    return
  fi

  REC_EMAIL="$(jwt_claim "$id_token" '.email')"
  if [[ -z "$REC_EMAIL" ]]; then
    REC_EMAIL="$(jwt_claim "$id_token" '.preferred_username')"
  fi
  REC_PLAN="$(jwt_claim "$id_token" '.["https://api.openai.com/auth"].chatgpt_plan_type')"
  REC_PLAN_UNTIL="$(jwt_claim "$id_token" '.["https://api.openai.com/auth"].chatgpt_subscription_active_until')"
  REC_PLAN_CHECKED_AT="$(jwt_claim "$id_token" '.["https://api.openai.com/auth"].chatgpt_subscription_last_checked')"

  return 0
}

usage_limit_reason_from_line() {
  local line="$1"

  if [[ "$line" == *"send a request to your admin"* ]]; then
    printf '%s\n' "contact_admin"
  elif [[ "$line" == *"Upgrade to Pro"* ]] && [[ "$line" == *"purchase more credits"* ]]; then
    printf '%s\n' "upgrade_or_purchase_credits"
  elif [[ "$line" == *"Upgrade to Pro"* ]]; then
    printf '%s\n' "upgrade_to_pro"
  elif [[ "$line" == *"purchase more credits"* ]]; then
    printf '%s\n' "purchase_credits"
  else
    printf '%s\n' "usage_limit"
  fi
}

usage_record_apply_limit_log() {
  local log_file="$1"
  local line

  if [[ ! -f "$log_file" ]]; then
    return
  fi

  line="$(grep -E "^[0-9]{4}-[0-9]{2}-[0-9]{2}T.*codex_core::codex: Turn error: You've hit your usage limit\\." "$log_file" | tail -n 1 || true)"
  if [[ -z "$line" ]]; then
    return
  fi

  REC_LAST_LIMIT_AT="${line%%  INFO*}"
  REC_RETRY_AT="$(printf '%s\n' "$line" | sed -n 's/.*try again at \(.*\)\./\1/p')"
  REC_REASON="$(usage_limit_reason_from_line "$line")"

  if [[ "$REC_AUTH" == "saved" ]]; then
    if retry_is_future "$REC_RETRY_AT"; then
      REC_STATUS="limited"
    else
      REC_STATUS="limit_seen"
    fi
  fi

  return 0
}

usage_record_apply_rate_line() {
  local rate_line="$1"
  local primary_reset_epoch secondary_reset_epoch rate_plan

  if [[ -z "$rate_line" ]] || ! command -v jq >/dev/null 2>&1; then
    return
  fi

  REC_LIMITS_AT="$(printf '%s' "$rate_line" | jq -r '.timestamp // empty' 2>/dev/null || true)"
  REC_PRIMARY_USED="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.primary.used_percent // empty' 2>/dev/null || true)"
  REC_PRIMARY_WINDOW_MIN="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.primary.window_minutes // empty' 2>/dev/null || true)"
  primary_reset_epoch="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.primary.resets_at // empty' 2>/dev/null || true)"
  REC_PRIMARY_RESET_AT="$(epoch_to_utc "$primary_reset_epoch")"
  REC_SECONDARY_USED="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.secondary.used_percent // empty' 2>/dev/null || true)"
  REC_SECONDARY_WINDOW_MIN="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.secondary.window_minutes // empty' 2>/dev/null || true)"
  secondary_reset_epoch="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.secondary.resets_at // empty' 2>/dev/null || true)"
  REC_SECONDARY_RESET_AT="$(epoch_to_utc "$secondary_reset_epoch")"
  rate_plan="$(printf '%s' "$rate_line" | jq -r '.payload.rate_limits.plan_type // empty' 2>/dev/null || true)"

  if [[ -n "$rate_plan" ]]; then
    REC_PLAN="$rate_plan"
  fi

  if percent_ge_100 "$REC_SECONDARY_USED"; then
    REC_STATUS="weekly_limited"
    REC_REASON="weekly_limit"
    [[ -z "$REC_RETRY_AT" ]] && REC_RETRY_AT="$REC_SECONDARY_RESET_AT"
  elif percent_ge_100 "$REC_PRIMARY_USED"; then
    REC_STATUS="session_limited"
    REC_REASON="session_5h_limit"
    [[ -z "$REC_RETRY_AT" ]] && REC_RETRY_AT="$REC_PRIMARY_RESET_AT"
  elif [[ "$REC_AUTH" == "saved" ]] && [[ -n "$REC_PRIMARY_USED$REC_SECONDARY_USED" ]]; then
    REC_STATUS="ready"
    REC_REASON=""
    REC_RETRY_AT=""
    REC_LAST_LIMIT_AT=""
  fi

  return 0
}

usage_record_finalize() {
  if [[ -z "$REC_AUTH_MODE" ]]; then
    REC_AUTH_MODE="unknown"
  fi
  if [[ -z "$REC_PLAN" ]]; then
    REC_PLAN="unknown"
  fi
  if [[ -z "$REC_STATUS" ]]; then
    REC_STATUS="unknown"
  fi

  return 0
}

# Usage data is inferred locally from saved auth and the most recent CLI log entry.
load_usage_record() {
  local account="$1"
  local current="$2"
  local default="$3"
  local dir

  usage_reset_record
  dir="$(account_dir "$account")"

  REC_ACCOUNT="$account"
  REC_PATH="$dir"
  [[ "$account" == "$current" ]] && REC_CURRENT="yes"
  [[ "$account" == "$default" ]] && REC_DEFAULT="yes"

  usage_record_apply_auth_file "$dir/auth.json"
  usage_record_apply_limit_log "$dir/log/codex-tui.log"
  usage_record_apply_rate_line "$(latest_token_count_line "$dir")"
  usage_record_finalize

  return 0
}

