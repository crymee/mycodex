  jq -cn \
    --arg account "$REC_ACCOUNT" \
    --arg path "$REC_PATH" \
    --arg current "$REC_CURRENT" \
    --arg default "$REC_DEFAULT" \
    --arg auth "$REC_AUTH" \
    --arg auth_mode "$REC_AUTH_MODE" \
    --arg email "$REC_EMAIL" \
    --arg plan "$REC_PLAN" \
    --arg plan_until "$REC_PLAN_UNTIL" \
    --arg plan_checked_at "$REC_PLAN_CHECKED_AT" \
    --arg status "$REC_STATUS" \
    --arg reason "$REC_REASON" \
    --arg retry_at "$REC_RETRY_AT" \
    --arg last_limit_at "$REC_LAST_LIMIT_AT" \
    --arg last_refresh "$REC_LAST_REFRESH" \
    --arg limits_at "$REC_LIMITS_AT" \
    --arg primary_used "$REC_PRIMARY_USED" \
    --arg primary_window_min "$REC_PRIMARY_WINDOW_MIN" \
    --arg primary_reset_at "$REC_PRIMARY_RESET_AT" \
    --arg secondary_used "$REC_SECONDARY_USED" \
    --arg secondary_window_min "$REC_SECONDARY_WINDOW_MIN" \
    --arg secondary_reset_at "$REC_SECONDARY_RESET_AT" \
    --arg account_id "$REC_ACCOUNT_ID" \
    '{
      account: $account,
      path: $path,
      current: ($current == "yes"),
      default: ($default == "yes"),
      auth: $auth,
      auth_mode: $auth_mode,
      email: $email,
      plan: $plan,
      plan_until: $plan_until,
      plan_checked_at: $plan_checked_at,
      status: $status,
      reason: $reason,
      retry_at: $retry_at,
      last_limit_at: $last_limit_at,
      last_refresh: $last_refresh,
      limits_at: $limits_at,
      session_5h: {
        used_percent: $primary_used,
        window_minutes: $primary_window_min,
        reset_at: $primary_reset_at
      },
      weekly: {
        used_percent: $secondary_used,
        window_minutes: $secondary_window_min,
        reset_at: $secondary_reset_at
      },
      account_id: $account_id
    }'
}

render_usage_record_detail() {
  ui_section "Usage Status"
  ui_kv "account" "$REC_ACCOUNT"
  ui_kv "current" "$REC_CURRENT"
  ui_kv "default" "$REC_DEFAULT"
  ui_kv "auth" "$REC_AUTH"
  ui_kv "auth_mode" "$REC_AUTH_MODE"
  [[ -n "$REC_EMAIL" ]] && ui_kv "email" "$REC_EMAIL"
  ui_kv "plan" "$REC_PLAN"
  ui_kv "status" "$REC_STATUS"
  [[ -n "$REC_REASON" ]] && ui_kv "reason" "$REC_REASON"
  [[ -n "$REC_RETRY_AT" ]] && ui_kv "retry_at" "$(format_datetime_local "$REC_RETRY_AT")"
  [[ -n "$REC_LAST_LIMIT_AT" ]] && ui_kv "last_limit" "$(format_datetime_local "$REC_LAST_LIMIT_AT")"
  [[ -n "$REC_LAST_REFRESH" ]] && ui_kv "last_refresh" "$(format_datetime_local "$REC_LAST_REFRESH")"
  [[ -n "$REC_LIMITS_AT" ]] && ui_kv "limits_at" "$(format_datetime_local "$REC_LIMITS_AT")"
  [[ -n "$REC_PRIMARY_USED" ]] && ui_kv "5h_used" "$(format_percent "$REC_PRIMARY_USED")"
  [[ -n "$REC_PRIMARY_RESET_AT" ]] && ui_kv "5h_reset" "$(format_datetime_local "$REC_PRIMARY_RESET_AT")"
  [[ -n "$REC_SECONDARY_USED" ]] && ui_kv "week_used" "$(format_percent "$REC_SECONDARY_USED")"
  [[ -n "$REC_SECONDARY_RESET_AT" ]] && ui_kv "week_reset" "$(format_datetime_local "$REC_SECONDARY_RESET_AT")"
  [[ -n "$REC_PLAN_UNTIL" ]] && ui_kv "plan_until" "$(format_datetime_local "$REC_PLAN_UNTIL")"
  [[ -n "$REC_PLAN_CHECKED_AT" ]] && ui_kv "plan_check" "$(format_datetime_local "$REC_PLAN_CHECKED_AT")"
  [[ -n "$REC_ACCOUNT_ID" ]] && ui_kv "account_id" "$REC_ACCOUNT_ID"
  ui_kv "path" "$REC_PATH"
  ui_note "Times in this view use local time ($(local_time_zone_label))."
  ui_note "This view is local-first and may lag behind live billing or usage state."
}

cmd_usage() {
  local output_format="text"
  local selected_account=""
  local dir account
  local -a accounts=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json)
        output_format="json"
        ;;
      -h|--help)
        usage_cmd_help
        return
        ;;
      -*)
        ui_error "unknown flag for usage: $1"
        exit 1
        ;;
      *)
        if [[ -n "$selected_account" ]]; then
          ui_error "usage accepts at most one account."
          exit 1
        fi
        selected_account="$1"
        ;;
    esac
    shift
  done

  load_marker_state

  if [[ -n "$selected_account" ]]; then
    validate_account "$selected_account"
    dir="$(account_dir "$selected_account")"
    if [[ ! -d "$dir" ]]; then
      ui_error "account '$selected_account' was not found."
      exit 1
    fi
    accounts=("$selected_account")
  else
    collect_saved_accounts
    accounts=("${SCANNED_ACCOUNTS[@]}")
  fi

  if [[ "${#accounts[@]}" -eq 0 ]]; then
    show_no_saved_accounts_message "$SCANNED_HIDDEN_STUB_COUNT"
    return
  fi

  if [[ "$output_format" == "json" ]]; then
    if ! command -v jq >/dev/null 2>&1; then
      ui_error "'jq' is required for mycodex usage --json."
      exit 1
    fi

    printf '[\n'
    local first=1
    for account in "${accounts[@]}"; do
      load_usage_record "$account" "$MARKER_CURRENT" "$MARKER_DEFAULT"
      if [[ "$first" -eq 0 ]]; then
        printf ',\n'
      fi
      render_usage_record_json
      first=0
    done
    printf '\n]\n'
    return
  fi

  if [[ -n "$selected_account" ]]; then
    load_usage_record "$selected_account" "$MARKER_CURRENT" "$MARKER_DEFAULT"
    render_usage_record_detail
    return
  fi

  ui_section "Usage Overview"
  printf '%-16s %-30s %-8s %-8s %-16s %-8s %-9s %-16s %s\n' "ACCOUNT" "EMAIL" "CURRENT" "PLAN" "STATUS" "5H_USED" "WEEK_USED" "5H_RESET" "WEEK_RESET"
  for account in "${accounts[@]}"; do
    load_usage_record "$account" "$MARKER_CURRENT" "$MARKER_DEFAULT"
    printf '%-16s %-30s %-8s %-8s %-16s %-8s %-9s %-16s %s\n' \
      "$REC_ACCOUNT" \
      "${REC_EMAIL:--}" \
      "$REC_CURRENT" \
      "$REC_PLAN" \
      "$REC_STATUS" \
      "$(format_percent "$REC_PRIMARY_USED")" \
      "$(format_percent "$REC_SECONDARY_USED")" \
      "$(format_datetime_local_or_dash "$REC_PRIMARY_RESET_AT" table)" \
      "$(format_datetime_local_or_dash "$REC_SECONDARY_RESET_AT" table)"
  done
  ui_note "Reset times in text output use local time ($(local_time_zone_label)); --json keeps raw timestamps."
  ui_note "5h/week fields come from the latest local token_count event; status still falls back to auth and CLI logs when needed."
  show_hidden_stub_note "$SCANNED_HIDDEN_STUB_COUNT"
}

cmd_login() {
  local account="$1"
  validate_account "$account"
  ensure_codex
  setup_account_dir "$account"
  set_current "$account"
  local dir
  dir="$(account_dir "$account")"
  ui_section "Login"
  ui_kv "account" "$account"
  ui_kv "codex_home" "$dir"
  ui_note "Authentication will be stored under this account directory."
  CODEX_HOME="$dir" codex login
}

cmd_use() {
  local account="$1"
  shift || true
  validate_account "$account"

  if [[ "$#" -gt 0 ]]; then
    ui_error "'use' only selects an account and does not launch codex."
    ui_note "Run: $BIN_NAME use $account"
    ui_note "Then run plain: codex <args...>"
    exit 1
  fi

  setup_account_dir "$account"
  set_current "$account"
  local dir
  dir="$(account_dir "$account")"

  ui_ok "Current account set to '$account'."
  ui_kv "codex_home" "$dir"
  ui_note "Run 'codex' to start Codex with this account in your shell."
}

cmd_list() {
  mkdir -p "$BASE_DIR"
  local current default

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help)
        cat <<'EOF2'
Usage:
  mycodex list

Notes:
  List hides stub accounts that do not have saved auth.json.
EOF2
        return
        ;;
      *)
        ui_error "unknown flag for list: $1"
        exit 1
        ;;
    esac
    shift
  done

  load_marker_state
  current="$MARKER_CURRENT"
  default="$MARKER_DEFAULT"

  local found=0
  ui_section "Accounts"
  printf '%-16s %-8s %-8s %-10s %-30s %s\n' "ACCOUNT" "CURRENT" "DEFAULT" "AUTH" "EMAIL" "PATH"
  local name
  collect_saved_accounts
  for name in "${SCANNED_ACCOUNTS[@]}"; do
    found=1
    load_usage_record "$name" "$current" "$default"
    printf '%-16s %-8s %-8s %-10s %-30s %s\n' \
      "$REC_ACCOUNT" \
      "$REC_CURRENT" \
      "$REC_DEFAULT" \
      "$REC_AUTH" \
      "${REC_EMAIL:--}" \
      "$REC_PATH"
  done
  if [[ "$found" -eq 0 ]]; then
    show_no_saved_accounts_message "$SCANNED_HIDDEN_STUB_COUNT"
    return
  fi
  show_hidden_stub_note "$SCANNED_HIDDEN_STUB_COUNT"
}

cmd_current() {
  local current
  current="$(get_current || true)"
  if [[ -n "$current" ]]; then
    echo "$current"
  else
    echo "No current account set."
    exit 1
  fi
}

cmd_default() {
  local account="$1"
  validate_account "$account"
  setup_account_dir "$account"
  set_default "$account"
  ui_ok "Default account set to '$account'."
}

cmd_prune() {
  local dry_run="no"
  local current default account
  local removed_count=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run)
        dry_run="yes"
        ;;
      -h|--help)
        cat <<'EOF2'
Usage:
  mycodex prune
  mycodex prune --dry-run

What it removes:
  Stub accounts without saved auth.json whose directory only contains config.toml.
EOF2
        return
        ;;
      *)
        ui_error "unknown flag for prune: $1"
        exit 1
        ;;
    esac
    shift
  done

  load_marker_state
  current="$MARKER_CURRENT"
  default="$MARKER_DEFAULT"
  collect_prunable_accounts

  for account in "${SCANNED_ACCOUNTS[@]}"; do
    if [[ "$dry_run" == "yes" ]]; then
      printf 'would_prune  %s\n' "$account"
      continue
    fi

    rm -rf "$(account_dir "$account")"
    if [[ "$current" == "$account" ]]; then
      clear_current
    fi
    if [[ "$default" == "$account" ]]; then
      clear_default
    fi
    printf 'pruned       %s\n' "$account"
    removed_count=$((removed_count + 1))
  done

  if [[ "${#SCANNED_ACCOUNTS[@]}" -eq 0 ]]; then
    ui_note "No removable stub accounts found."
    return
  fi

  if [[ "$dry_run" == "yes" ]]; then
    ui_note "Dry run only. Re-run without --dry-run to remove these stub accounts."
    return
  fi

  ui_ok "Removed $removed_count stub account(s)."
}

# Important: "logout" in this wrapper is intentionally non-destructive.
# It only removes local current/default pointers so switching accounts stays fast.
# Saved credentials remain on disk; use cmd_forget() to actually remove them.
cmd_logout() {
  local account="$1"
  validate_account "$account"
  local changed
  load_marker_state
  changed=0

  if [[ "$MARKER_CURRENT" == "$account" ]]; then
    clear_current
    changed=1
  fi

  if [[ "$MARKER_DEFAULT" == "$account" ]]; then
    clear_default
    changed=1
  fi

  if [[ "$changed" -eq 1 ]]; then
    ui_ok "Logged out from '$account' locally; saved auth was kept."
  else
    ui_warn "Account '$account' is not active; saved auth was kept."
  fi

  ui_note "Use '$BIN_NAME forget $account' if you want to remove saved auth."
}

# "forget" is the destructive counterpart to cmd_logout().
# It deletes the saved auth for an account. If that account is still active,
# automatically switch current/default markers to another saved account first when possible.
cmd_forget() {
  local account="$1"
  local dir removed_marker selected_replacement

  validate_account "$account"
  dir="$(account_dir "$account")"
  load_marker_state
  removed_marker=0
  selected_replacement=""

  if [[ "$MARKER_CURRENT" == "$account" || "$MARKER_DEFAULT" == "$account" ]]; then
    selected_replacement="$(first_saved_replacement_account "$account")"
    if [[ -z "$selected_replacement" ]]; then
      ui_note "Account '$account' is active and no other saved account is available as a replacement."
      ui_note "Current/default pointers will be cleared after forget."
    fi
  fi

  rm -f "$dir/auth.json"

  if [[ "$MARKER_CURRENT" == "$account" ]]; then
    if [[ -n "$selected_replacement" ]]; then
      set_current "$selected_replacement"
    else
      clear_current
    fi
    removed_marker=1
  fi

  if [[ "$MARKER_DEFAULT" == "$account" ]]; then
    if [[ -n "$selected_replacement" ]]; then
      set_default "$selected_replacement"
    else
      clear_default
    fi
    removed_marker=1
  fi

  ui_ok "Removed saved auth for '$account' at $dir/auth.json"
  if [[ -n "$selected_replacement" ]]; then
    ui_note "Switched current/default pointers from '$account' to '$selected_replacement' before forget."
  elif [[ "$removed_marker" -eq 1 ]]; then
    ui_note "Cleared current/default pointers for '$account'."
  fi
}

cmd_where() {
  local account="$1"
  validate_account "$account"
  account_dir "$account"
}

main() {
  local cmd="${1:-help}"
  case "$cmd" in
    install)
      shift
      cmd_install "$@"
      ;;
    login)
      shift
      cmd_login "${1:-}"
      ;;
    use)
      shift
      cmd_use "${1:-}" "${@:2}"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    usage)
      shift
      cmd_usage "$@"
      ;;
    current)
      cmd_current
      ;;
    default)
      shift
      cmd_default "${1:-}"
      ;;
    uninstall)
      shift
      cmd_uninstall "$@"
      ;;
    logout)
      shift
      cmd_logout "${1:-}"
      ;;
    forget)
      shift
      cmd_forget "${1:-}"
      ;;
    prune)
      shift
      cmd_prune "$@"
      ;;
    where)
      shift
      cmd_where "${1:-}"
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      ui_error "unknown command: $cmd"
      usage
      exit 1
      ;;
  esac
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  init_ui
  main "$@"
else
  mycodex_enable_shell_integration
fi
